      },
      "step": {
        "set_options": {
          "title": "Add WeCom",
          "data": {
            "bot_id": "Bot ID",
            "secret": "Secret"
          }
        }
      }
    },
    "qq": {
      "entry_type": "QQ Service",
      "initiate_flow": {
