{
  "config": {
    "step": {
      "user": {
        "title": "即时通信合集",
        "description": "Choose one global conversation agent. Providers are added later from this integration page."
      }
    },
    "error": {
      "cannot_connect": "Failed to validate provider config",
      "agent_id_required": "agent_id is required",
      "auth_not_confirmed": "QR login not confirmed yet"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Set Global Agent",
        "description": "All providers use this single conversation agent."
      }
    },
    "error": {
      "agent_id_required": "agent_id is required"
    }
  },
  "services": {
    "send_message": {
      "name": "Send Message",
      "description": "Send a message via the selected IM provider.",
      "fields": {
        "wechat_account_id": {
          "name": "WeChat Account",
          "description": "Required when using WeChat with multiple bound accounts. Use the WeChat subentry title suffix or the full title, for example: WeChat (abc123@im.bot)."
        },
        "camera_entity": {
          "name": "Camera Entity",
          "description": "Capture a snapshot from this camera and send it as an image. Currently supported by WeChat, WeCom, Feishu, and QQ."
        }
      }
    }
  },
  "config_subentries": {
    "feishu": {
      "entry_type": "Feishu Service",
      "initiate_flow": {
        "user": "Add Feishu",
        "reconfigure": "Feishu Settings"
      },
      "step": {
        "set_options": {
          "title": "Add Feishu",
          "data": {
            "app_id": "App ID",
            "app_secret": "App Secret"
          }
        }
      }
    },
    "wecom": {
      "entry_type": "WeCom Service",
      "initiate_flow": {
        "user": "Add WeCom",
        "reconfigure": "WeCom Settings"
      },
      "step": {
        "set_options": {
          "title": "Add WeCom",
          "data": {
            "bot_id": "Bot ID",
            "secret": "Secret"
          }
        }
      }
    },
    "qq": {
      "entry_type": "QQ Service",
      "initiate_flow": {
        "user": "Add QQ",
        "reconfigure": "QQ Settings"
      },
      "step": {
        "set_options": {
          "title": "Add QQ",
          "data": {
            "qq_app_id": "App ID",
            "qq_client_secret": "App Secret"
          }
        }
      }
    },
    "dingtalk": {
      "entry_type": "DingTalk Service",
      "initiate_flow": {
        "user": "Add DingTalk",
        "reconfigure": "DingTalk Settings"
      },
      "step": {
        "set_options": {
          "title": "Add DingTalk",
          "data": {
            "dingtalk_client_id": "Client ID",
            "dingtalk_client_secret": "Client Secret"
          }
        }
      }
    },
    "wechat": {
      "entry_type": "WeChat",
      "initiate_flow": {
        "user": "Add WeChat"
      },
      "step": {
        "auth_wait": {
          "title": "Waiting for WeChat Login",
          "description": "Scan the QR in WeChat and confirm on the phone. After confirmation, click Submit.\n\n{qr_markdown}\n\nQR URL: {qr_url}"
        }
      }
    },
    "xiaoyi": {
      "entry_type": "XiaoYi",
      "initiate_flow": {
        "user": "Add XiaoYi",
        "reconfigure": "XiaoYi Settings"
      },
      "step": {
        "set_options": {
          "title": "Add XiaoYi",
          "data": {
            "xiaoyi_ak": "Access Key",
            "xiaoyi_sk": "Secret Key",
            "xiaoyi_agent_id": "XiaoYi Agent ID"
          }
        }
      }
    }
  }
}
